# ── Infrastructure Secrets ─────────────────────────────────────────────────
# Copy to .env.infra and fill in production values. Never commit this file.

# PostgreSQL
POSTGRES_USER=fraud_user
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_SECURE_PASSWORD

# Neo4j
NEO4J_AUTH=neo4j/CHANGE_ME_GENERATE_SECURE_PASSWORD

# Redis
REDIS_PASSWORD=CHANGE_ME_GENERATE_SECURE_PASSWORD
