# ── Application Service Secrets ────────────────────────────────────────────
# Copy to .env.services and fill in production values. Never commit this file.

# Database connection (used by API + risk-engine)
DATABASE_URL=postgresql://fraud_user:CHANGE_ME@postgres:5432/fraudshield

# Redis connection
REDIS_URL=redis://:CHANGE_ME@redis:6379

# API key salt (generate: openssl rand -hex 32)
API_KEY_SALT=CHANGE_ME_GENERATE_WITH_OPENSSL

# API keys accepted by services (comma-separated)
API_KEYS=CHANGE_ME_GENERATE_SECURE_KEYS

# Device binding JWT secret (min 32 chars)
DEVICE_TOKEN_SECRET=CHANGE_ME_GENERATE_SECURE_SECRET_MIN_32_CHARS

# PostgreSQL (device-binding uses individual vars)
POSTGRES_USER=fraud_user
POSTGRES_PASSWORD=CHANGE_ME

# Neo4j (graph-engine)
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME

# CORS
DASHBOARD_URL=https://your-dashboard-domain.com
CORS_ORIGIN=https://your-dashboard-domain.com
CORS_ORIGINS=https://your-dashboard-domain.com
