<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#0D1117">

    <!-- Logo / Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🛡️ Swifter Fraud Shield"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#58A6FF"
        android:gravity="center"
        android:paddingBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SDK Integration Demo — MoMo Send Money"
        android:textSize="13sp"
        android:textColor="#8B949E"
        android:gravity="center"
        android:paddingBottom="32dp"/>

    <!-- Recipient -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Recipient Phone / Wallet"
        android:textColor="#C9D1D9"
        android:textSize="14sp"
        android:paddingBottom="6dp"/>

    <EditText
        android:id="@+id/etRecipient"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="+27 82 100 0010"
        android:inputType="phone"
        android:textColor="#C9D1D9"
        android:textColorHint="#484F58"
        android:background="@drawable/input_bg"
        android:padding="14dp"
        android:layout_marginBottom="16dp"/>

    <!-- Amount -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Amount (ZAR)"
        android:textColor="#C9D1D9"
        android:textSize="14sp"
        android:paddingBottom="6dp"/>

    <EditText
        android:id="@+id/etAmount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="0.00"
        android:inputType="numberDecimal"
        android:textColor="#C9D1D9"
        android:textColorHint="#484F58"
        android:background="@drawable/input_bg"
        android:padding="14dp"
        android:layout_marginBottom="32dp"/>

    <!-- Send Button -->
    <Button
        android:id="@+id/btnSend"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Send Money →"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#238636"
        android:textColor="@android:color/white"/>

    <!-- Progress -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:visibility="gone"/>

    <!-- Risk Decision Result -->
    <TextView
        android:id="@+id/tvResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:fontFamily="monospace"
        android:textSize="14sp"
        android:textColor="#8B949E"
        android:gravity="center"/>

</LinearLayout>
