{
  "name": "@payguard/sdk",
  "version": "1.0.0",
  "description": "PayGuard Fraud Detection SDK — Real-time fraud prevention for payments",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
