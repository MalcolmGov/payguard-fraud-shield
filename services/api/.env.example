# PayGuard — Signal API
# Copy to .env and fill in real values before running

PORT=3001
NODE_ENV=development

# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://fraud_user:CHANGE_ME@localhost:5432/fraudshield

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME@localhost:6379

# ── Kafka ──────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── API ────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
API_KEY_SALT=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# ── Downstream services ────────────────────────────────────
RISK_ENGINE_URL=http://localhost:8001
DEVICE_BINDING_SERVICE_URL=http://localhost:3002

# ── CORS ───────────────────────────────────────────────────
DASHBOARD_URL=http://localhost:5173
