# PayGuard — Device Binding Service
# Copy to .env and fill in real values before running

# ── Server ─────────────────────────────────────────────────
PORT=3002

# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=payguard_devices
POSTGRES_USER=fraud_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_SSL=false

# ── Redis ──────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1

# ── JWT ────────────────────────────────────────────────────
# Must be at least 32 chars. Generate: openssl rand -hex 32
DEVICE_TOKEN_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# ── API Keys ───────────────────────────────────────────────
# Comma-separated list of valid API keys
API_KEYS=pg_sandbox_001,pg_sandbox_002

# ── OTP ────────────────────────────────────────────────────
OTP_TTL_SECONDS=600
OTP_LENGTH=6
# SMS provider: 'mock' | 'africas_talking' | 'infobip'
SMS_PROVIDER=mock
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_USERNAME=
INFOBIP_API_KEY=
INFOBIP_BASE_URL=

# ── CORS ───────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development
